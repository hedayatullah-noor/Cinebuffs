                            </div>
                            <p className="text-gray-500 dark:text-gray-400 text-[10px] uppercase font-black tracking-[0.2em]">Secure Editorial Portal • Track your narrative contributions</p>
                        </div>
                    </div>

                    {/* Floating Add Buttons */}
