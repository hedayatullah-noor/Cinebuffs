generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Role: "ADMIN" | "MODERATOR" | "USER"
// ReviewStatus: "PENDING" | "APPROVED" | "REJECTED"
// MediaType: "MOVIE" | "SERIES" | "BLOG"

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  image            String?   @db.LongText
  role             String    @default("USER")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  bio              String?
  createdAt        DateTime  @default(now())

  reviews  Review[]
  comments Comment[]
}

model Review {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique

  /*
   * TWO IMAGE SYSTEM
   * -----------------
   * posterImage  → vertical 2:3 poster (used on ReviewCard)
   *                Recommended size: 400 × 600 px
   *
   * sliderImage  → horizontal 16:9 banner (used on HeroSlider & Featured Review)
   *                Recommended size: 1280 × 720 px
   *
   * sliderImage is optional — if not provided, posterImage is used as fallback.
   */
  posterImage String   @db.LongText
  sliderImage String?  @db.LongText

  rating      Float
  genre       String
  type        String
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  content     String   @db.LongText
  director    String?
  cast        String?
  availableOn String?
  gallery     String?  @db.Text
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  approvedAt  DateTime?

  comments Comment[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Subscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}
