                                    <th className="p-5 font-black hidden md:table-cell">Submission Date</th>
                                    <th className="p-5 font-black">Audit Status</th>
                                    <th className="p-5 pr-8 text-right font-black">Archive Options</th>
                                </tr>
                            </thead>
                            <tbody className="text-sm">
