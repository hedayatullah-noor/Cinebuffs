                                </div>

                                {/* ── Info ── */}
                                <div style={{ flex: 1, display: "flex", flexDirection: "column", gap: 10 }}>
                                    {/* Name */}
                                    <h2 style={{
                                        fontFamily: "var(--font-serif)",
                                        fontWeight: 700,
                                        fontSize: "clamp(1.25rem, 2.5vw, 1.6rem)",
                                        color: "var(--color-text-main)",
                                        margin: 0,
                                        lineHeight: 1.2,
                                    }}>
                                        {person.name}
